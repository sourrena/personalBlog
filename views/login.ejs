<h1>Admin Login</h1>

<% if (error) { %>
  <p style="color: red;"><%= error %></p>
<% } %>

<form action="/login" method="POST">
  <div>
    <label for="password">Password</label>
    <input type="password" id="password" name="password">
  </div>

  <button type="submit">Login</button>
</form>

<a href="/">Back to Home</a>